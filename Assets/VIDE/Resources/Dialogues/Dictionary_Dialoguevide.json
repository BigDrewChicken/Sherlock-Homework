{"dID":34516,"playerDiags":6,"actionNodes":0,"startPoint":0,"loadTag":"","previewPanning":false,"autosave":true,"locEdit":false,"showSettings":true,"pd_isp_0":false,"pd_rect_0":[450,180],"pd_comSize_0":1,"pd_ID_0":0,"pd_pTag_0":"Dictionary","pd_sprite_0":"","pd_expand_0":false,"pd_vars0":0,"pd_0_com_0iSet":0,"pd_0_com_0oAns":1,"pd_0_com_0oAct":-1,"pd_0_com_0text":"The English Grammar Guide is open. Which section would you like to study?","pd_0_com_0extraD":"ExtraData","pd_0_com_0showmore":false,"pd_0_com_0visible":true,"pd_0_com_0audio":"","pd_0_com_0sprite":"","pd_isp_1":false,"pd_rect_1":[840,240],"pd_comSize_1":1,"pd_ID_1":1,"pd_pTag_1":"Dictionary","pd_sprite_1":"","pd_expand_1":false,"pd_vars1":0,"pd_1_com_0iSet":-1,"pd_1_com_0oAns":2,"pd_1_com_0oAct":-1,"pd_1_com_0text":"RULE: Adjectives (like 'obvious') describe a state of being. They cannot be used as verbs (action words). You cannot 'obvious' someone.","pd_1_com_0extraD":"ExtraData","pd_1_com_0showmore":false,"pd_1_com_0visible":true,"pd_1_com_0audio":"","pd_1_com_0sprite":"","pd_isp_2":false,"pd_rect_2":[1250,270],"pd_comSize_2":1,"pd_ID_2":2,"pd_pTag_2":"Dictionary","pd_sprite_2":"","pd_expand_2":false,"pd_vars2":0,"pd_2_com_0iSet":-1,"pd_2_com_0oAns":3,"pd_2_com_0oAct":-1,"pd_2_com_0text":"RULE: Passive Voice (e.g., 'was taken') is often used to hide the 'doer' of an action. Active Voice (e.g., 'I took') names the subject directly.","pd_2_com_0extraD":"ExtraData","pd_2_com_0showmore":false,"pd_2_com_0visible":true,"pd_2_com_0audio":"","pd_2_com_0sprite":"","pd_isp_3":false,"pd_rect_3":[1630,310],"pd_comSize_3":1,"pd_ID_3":3,"pd_pTag_3":"Dictionary","pd_sprite_3":"","pd_expand_3":false,"pd_vars3":0,"pd_3_com_0iSet":-1,"pd_3_com_0oAns":4,"pd_3_com_0oAct":-1,"pd_3_com_0text":"Everyone' is a singular indefinite pronoun. Use 'his/her,' not 'their.' Also, subjects like 'English' are Proper Nouns and MUST be capitalized.","pd_3_com_0extraD":"ExtraData","pd_3_com_0showmore":false,"pd_3_com_0visible":true,"pd_3_c