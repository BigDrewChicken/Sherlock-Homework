  langs: []
  S_playerDiags:
  - commentCount: 1
    s_comment:
    - text: I've been staring out this window the whole time. I never even walked
        near the teacher's desk!
      extraData: ExtraData
      inputSetIndex: 0
      outputNodeIndex: 1
      outActionIndex: -1
      sprites: {fileID: 0}
      audios: {fileID: 0}
      visible: 1
    ID: 0
    pTag: Defendant 1
    sprite: {fileID: 0}
    vars: []
    varKeys: []
    isPlayer: 0
  - commentCount: 3
    s_comment:
    - text: You used 'oblivious' as a verb earlier; that grammar error proves you
        are lying about your location!
      extraData: ExtraData
      inputSetIndex: 1
      outputNodeIndex: 2
      outActionIndex: -1
      sprites: {fileID: 0}
      audios: {fileID: 0}
      visible: 1
    - text: Your use of 'literally' was actually figurative; I cannot trust a witness
        who uses such poor syntax!
      extraData: ExtraData
      inputSetIndex: 1
      outputNodeIndex: -1
      outActionIndex: -1
      sprites: {fileID: 0}
      audios: {fileID: 0}
      visible: 1
    - text: You failed to use a serial comma in your last statement; your lack of
        precision makes you a suspect!
      extraData: ExtraData
      inputSetIndex: 1
      outputNodeIndex: -1
      outActionIndex: -1
      sprites: {fileID: 0}
      audios: {fileID: 0}
      visible: 1
    ID: 1
    pTag: Detective
    sprite: {fileID: 0}
    vars: []
    varKeys: []
    isPlayer: 1
  - commentCount: 1
    s_comment:
    - text: Fine, I lied! I was at the bookshelf. But I saw Defendant 2 asking the
        teacher a question near the desk right before class ended. Go talk to them!
      extraData: ExtraData
      inputSetIndex: 2
      outputNodeIndex: -1
      outActionIndex: -1
      sprites: {fileID: 0}
      audios: {fileID: 0}
      visible: 1
